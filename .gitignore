# ── 保留的重要输出 ──
!data/*.csv
!output/*.csv
!output/*.json
!output/images/*.png
!reports/*.pdf
!reports/*.tex
!reports/*.docx

# ── 排除的不必要文件 ──
# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.ipynb

# Virtual environment
.venv/
venv/

# IDE
.vscode/
.idea/
.claude/

# OS
Thumbs.db
.DS_Store

# LaTeX build artifacts
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk

# Node / JS
node_modules/
package.json
package-lock.json
*.js

# PPT/Word temp files
~$*.pptx
~$*.docx
*.pptx

# Git lock
.git/index.lock
